# Render Deployment Environment Template
# Copy this to render-deploy.env and fill in your values

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dealpilot?retryWrites=true&w=majority

# Redis Cloud Connection
REDIS_URL=redis://:password@redis-xxxxx.c123.us-east-1-2.ec2.cloud.redislabs.com:16379

# Node Environment
NODE_ENV=production

# Backend Configuration
PORT=10000
JWT_SECRET=your_32_character_secret_key_here_change_this
JWT_EXPIRE=7d

# Frontend URL (Vercel)
FRONTEND_URL=https://dealpilot.vercel.app

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_SECRET=your_webhook_secret

# Google Gemini AI
GEMINI_API_KEY=your_google_gemini_api_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=noreply@dealpilot.com

# Render Deploy Hook (from Render Dashboard)
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-XXXXX?key=XXXXX
